{
  "name": "my-better-t-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "check-types": "npm run check-types --workspaces",
    "dev:web": "npm run dev --workspace web",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@my-better-t-app/env": "*",
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@my-better-t-app/config": "*",
    "typescript": "^5"
  },
  "packageManager": "npm@11.6.0"
}
